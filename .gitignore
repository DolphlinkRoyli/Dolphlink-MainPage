# ============================================================================
# DOLPHLINK Â· .gitignore
# ----------------------------------------------------------------------------
# Anything listed here stays LOCAL ONLY â€” never pushed to GitHub Pages.
# ============================================================================

# ---- All internal stuff lives here, one rule blocks it all -----------------
_local/

# ---- Build pipeline kept at root (relative paths) but not deployed ---------
build/
cms/
templates/

# ---- Personal deploy scripts (live at root for double-click convenience) ---
push-to-github.bat
push-to-github.ps1
push.bat
bump-version.bat

# ---- Original source assets â€” kept locally for re-processing ---------------
media/_orig/

# ---- OS / editor cruft -----------------------------------------------------
.DS_Store
Thumbs.db
*.tmp
*.swp
*.bak
.idea/
.vscode/
*.iml

# ---- Node / Python ---------------------------------------------------------
node_modules/
npm-debug.log
package-lock.json
yarn.lock
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ---- Logs ------------------------------------------------------------------
*.log

# ---- Build artifacts -------------------------------------------------------
*.min.css.map
*.min.js.map

# ---- Reorganization script itself (one-time use) --------------------------
reorganize-local.ps1
reorganize-local.bat
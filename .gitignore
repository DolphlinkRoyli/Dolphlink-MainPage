# ============================================================================
# DOLPHLINK · .gitignore
# ----------------------------------------------------------------------------
# Anything listed here is kept LOCAL ONLY — never pushed to GitHub Pages.
# The deployed site at https://dolphlinkroyli.github.io/Dolphlink-MainPage/
# only serves files NOT listed here.
# ============================================================================

# ----------------------------------------------------------------------------
# Original source assets — kept locally for re-processing, not deployed
# ----------------------------------------------------------------------------
media/_orig/

# ----------------------------------------------------------------------------
# OS / editor cruft
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.tmp
*.swp
*.bak
.idea/
.vscode/
*.iml

# ----------------------------------------------------------------------------
# Node
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log
package-lock.json
yarn.lock

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
*.log

# ----------------------------------------------------------------------------
# Build artifacts (auto-generated by GitHub Actions)
# .min files are committed by CI, but ignore local manual minify outputs
# ----------------------------------------------------------------------------
*.min.css.map
*.min.js.map
.backup-pre-refactor-*/

# ============================================================================
# PRIVATE / LOCAL-ONLY TOOLING — never push to public repo
# ============================================================================

# ----------------------------------------------------------------------------
# Personal deploy / dev scripts (have hardcoded GitHub username, paths, etc.)
# ----------------------------------------------------------------------------
push-to-github.bat
push-to-github.ps1
start-local-test.bat
cleanup-empty-stubs.bat
cleanup-empty-stubs.ps1

# ----------------------------------------------------------------------------
# Internal documentation (contains personal email, strategy notes, todos)
# ----------------------------------------------------------------------------
GITHUB-PUSH-GUIDE.md
REFACTOR-STATUS.md
CLEANUP-TODO.md
SITE-SPECIFICATION.md
DOLPHLINK_Site_Specification.md

# ----------------------------------------------------------------------------
# Build / CMS tooling (developer-only — site doesn't need these to run)
# ----------------------------------------------------------------------------
build/
cms/

# ----------------------------------------------------------------------------
# Strategy & internal planning docs
# ----------------------------------------------------------------------------
strategy/

# ----------------------------------------------------------------------------
# Integration setup scripts & internal READMEs (Apps Script source, OAuth
# setup notes — these belong in a private notes vault, not public Pages)
# ----------------------------------------------------------------------------
integrations/

# ----------------------------------------------------------------------------
# Local-only template extraction system (the BUILT HTML in index.html etc.
# is what's deployed; the source templates are dev-only)
# ----------------------------------------------------------------------------
templates/

# ----------------------------------------------------------------------------
# Architecture / template guide docs — useful for devs but not for end users
# Keep README.md as the only public-facing doc.
# ----------------------------------------------------------------------------
ARCHITECTURE.md
TEMPLATE-GUIDE.md

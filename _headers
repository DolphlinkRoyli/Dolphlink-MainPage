# Hosts that honour Netlify / Cloudflare Pages `_headers` syntax pick
# these up automatically. GitHub Pages ignores this file, so on GH
# Pages the site is missing the directives below — see comments in
# index.html.
#
# Why these aren't in <meta http-equiv> in index.html:
#   - frame-ancestors / X-Frame-Options: spec-required to be HTTP
#     header only; browsers IGNORE them from a meta tag.
#   - Cross-Origin-Opener-Policy:        same — header-only.
#   - Cross-Origin-Embedder-Policy:      same — header-only.
#   - Strict-Transport-Security:         header-only.
#
# CSP shape:
#   script-src 'self' + 2 sha256 hashes — every executable script is
#     either an external module from /js/ OR one of the two tiny inline
#     boot probes on index.html (err-shim / pwa registration). The
#     hashes pin EXACTLY those two; any third inline script gets blocked.
#   script-src-attr 'none' — defense-in-depth: blocks every inline
#     event handler (onclick=, onerror=, onload="…") site-wide so a
#     stored-XSS write into an attribute still can't execute JS.
#   connect-src 'self' https://dolphlink-api.roygto2013.workers.dev —
#     sme/build/ POSTs the intake form (signed JSON, HMAC-SHA256) to
#     our own Cloudflare Worker, which validates and forwards to
#     Resend → inbox. Nothing else cross-origin is needed.
#   form-action 'self' https://dolphlink-api.roygto2013.workers.dev —
#     same Worker URL, for the no-JS fallback path where the browser
#     does a classic form POST instead of our signed-JSON fetch.
#
# Test after deploy with https://securityheaders.com or
# Mozilla Observatory — target an A+ on both.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-Qvs/MYH5NgMInq3lPLn9u0l9OUeNrax9M+NJfICovvE=' 'sha256-vvt4KWwuNr51XfE5m+hzeNEGhiOfZzG97ccfqGsPwvE='; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob:; connect-src 'self' https://dolphlink-api.roygto2013.workers.dev; object-src 'none'; base-uri 'self'; form-action 'self' https://dolphlink-api.roygto2013.workers.dev; frame-ancestors 'none'; frame-src 'none'; worker-src 'self'; manifest-src 'self'; upgrade-insecure-requests

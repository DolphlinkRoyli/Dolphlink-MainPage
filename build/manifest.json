{
  "_": "DOLPHLINK build manifest. Each entry in `pages` produces one HTML output. Tokens are file-include placeholders ({{ TOKEN_NAME }}, uppercase). SEO data ({{ a.b }}, lowercase) is sourced from content/seo.json. Run: python3 build/build.py",
  "pages": [
    {
      "name": "homepage",
      "layout": "_layout.html",
      "output": "../index.html",
      "tokens": {
        "HEAD": "head.html",
        "NOSCRIPT_BANNER": "noscript-banner.html",
        "LOADER_SHELL": "loader-shell.html",
        "NAV": "nav.html",
        "HERO": "hero.html",
        "TRUST": "trust.html",
        "RELIABILITY": "reliability.html",
        "PORTFOLIO": "portfolio.html",
        "AUDIT": "audit.html",
        "INDUSTRIES": "industries.html",
        "DEPARTMENTS": "departments.html",
        "FOOTER": "footer.html",
        "PWA": "pwa.html"
      }
    },
    {
      "name": "card-page",
      "layout": "card-page.html",
      "output": "../card/index.html",
      "tokens": {}
    },
    {
      "name": "sme-page",
      "layout": "sme/_layout.html",
      "output": "../sme/index.html",
      "tokens": {
        "HEAD":      "sme/head.html",
        "HEADER":    "sme/header.html",
        "HERO":      "sme/hero.html",
        "BENEFITS":  "sme/benefits.html",
        "PRICING":   "sme/pricing.html",
        "USE_CASES":    "sme/use-cases.html",
        "INTEGRATIONS": "sme/integrations.html",
        "HOW":          "sme/how-it-works.html",
        "CTA":       "sme/cta.html",
        "FOOTER":    "sme/footer.html"
      }
    }
  ]
}
